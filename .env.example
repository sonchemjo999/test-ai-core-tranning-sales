# Web -> FastAPI shared auth key. Must match web AI_API_KEY.
AI_API_KEY=<change-me>

# Frontend origin allowed by CORS.
FRONTEND_URL=https://<change-me>

# LLM routing. LLM_PROVIDER: auto, openrouter, gpt, gemini, grok.
LLM_PROVIDER=auto
DEFAULT_MODEL=claude-sonnet-4-20250514
SALES_LLM_MODEL=
VOICE_LLM_PROVIDER=auto
VOICE_LLM_MODEL=
LOG_LEVEL=INFO

# API providers.
