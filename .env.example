AI_SERVICE_URL=
# Choose one or both providers
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# Default model
DEFAULT_MODEL=claude-sonnet-4-20250514
# DEFAULT_MODEL=gpt-4o

# Sale Train Agent (LangGraph) — OpenAI JSON calls
SALES_LLM_MODEL=google/gemini-2.5-flash-lite

# Logging
LOG_LEVEL=INFO

# AI Hook Logging (set by instructor)

GEMINI_API_KEY=
TTS_API_KEY=
