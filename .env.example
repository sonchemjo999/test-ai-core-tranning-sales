# Sale Train Agent — Environment Variables Template
# Copy this file to .env and fill in your API keys

# ── Railway Deployment ─────────────────────────────────────────────────
# Railway sets these automatically. Set FRONTEND_URL to your Next.js domain.
# PORT=8000            # Set automatically by Railway
# RAILWAY_PUBLIC_URL=  # Set automatically by Railway (e.g. https://xxx.up.railway.app)
FRONTEND_URL=https://your-frontend-app.vercel.app

# ── LLM Providers (at least one required) ──────────────────────────────
# Priority: OPEN_ROUTER_API > GEMINI_API_KEY > OPENAI_API_KEY

OPENAI_API_KEY=sk-...
OPEN_ROUTER_API=sk-or-...
GEMINI_API_KEY=...
GROQ_API_KEY=...

# Default model (Anthropic format for agent.py)
DEFAULT_MODEL=claude-sonnet-4-20250514

# LangGraph / FastAPI model (OpenAI-compatible endpoint)
# Recommended: google/gemini-2.5-flash-lite (fast, cheap via OpenRouter)
SALES_LLM_MODEL=google/gemini-2.5-flash-lite

# Voice streaming model
VOICE_LLM_MODEL=google/gemini-2.5-flash-lite

# ── Authentication ──────────────────────────────────────────────────────
AI_API_KEY=change-me-in-production

# ── Logging ────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Text-to-Speech ─────────────────────────────────────────────────────
# FPT.AI TTS
TTS_API_KEY=
TTS_VOICE=minhquang
TTS_SPEED=1

# ElevenLabs TTS (alternative)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5
