CARTESIA_API_KEY=
CARTESIA_MALE_VOICE_ID=
CARTESIA_FEMALE_VOICE_ID=

GROQ_API_KEY=

# Token secret for WebSocket Voice Authentication
WS_TOKEN_SECRET=

# Simli Avatar Streaming (optional — enables animated avatar in phone app)
SIMLI_ENABLED=false
SIMLI_API_KEY=
